{
  "name": "merror",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @merror/api dev",
    "dev:web": "pnpm --filter @merror/web dev",
    "dev:mobile": "pnpm --filter @merror/mobile start",
    "build:api": "pnpm --filter @merror/api build",
    "build:web": "pnpm --filter @merror/web build",
    "db:generate": "pnpm --filter @merror/api prisma:generate",
    "db:migrate": "pnpm --filter @merror/api prisma:migrate:dev",
    "db:push": "pnpm --filter @merror/api prisma:push",
    "db:seed": "pnpm --filter @merror/api prisma:seed",
    "db:studio": "pnpm --filter @merror/api prisma:studio",
    "push": "git add -A && git commit -m \"updated code\" && git push"
  },
  "devDependencies": {
    "next": "14.1.4",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.2.79",
      "@types/react-dom": "18.2.25"
    }
  }
}
