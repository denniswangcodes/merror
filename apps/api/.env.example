# ── Local development ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# In production, all values are injected by Render automatically.

# Postgres connection string (Render injects this from the linked database)
DATABASE_URL="postgresql://merror:merror_password@localhost:5434/merror_db?schema=public"

# JWT signing secrets — use long random strings in production
# Render generates these automatically via generateValue: true in render.yaml
JWT_SECRET="change-me-super-secret-jwt-key-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-super-secret-refresh-key-at-least-32-chars"

# Set to your Vercel deployment URL in production, e.g. https://merror.vercel.app
WEB_ORIGIN="http://localhost:3000"

NODE_ENV="development"
PORT=4000
